SELECT
  DATE, -- raw GDELT date , just in case!
  CAST(FLOOR(DATE / 1000000) AS INT64)                   AS DateOnly, -- helpful for python grouping and aggregating and saves python side variable faffing. 

  -- Source
  REGEXP_EXTRACT(DocumentIdentifier, r'https?://(?:www\.)?([^/]+)') AS NewsSource, -- the news provider name extracted from the article link
  DocumentIdentifier AS SourceURL,

  -- Headline
  REGEXP_EXTRACT(Extras, r'<PAGE_TITLE>(.*?)</PAGE_TITLE>') AS Headline, -- Headline from the extras data

  -- Full tone breakdown
  CAST(SPLIT(V2Tone, ',')[OFFSET(0)] AS FLOAT64) AS SentimentScore, -- overall tone of entire article (important to remember GDELT assesses the entire article even though i am only collecting headlines)
  CAST(SPLIT(V2Tone, ',')[OFFSET(1)] AS FLOAT64) AS Positive,
  CAST(SPLIT(V2Tone, ',')[OFFSET(2)] AS FLOAT64) AS Negative,
  CAST(SPLIT(V2Tone, ',')[OFFSET(3)] AS FLOAT64) AS Polarity,
  CAST(SPLIT(V2Tone, ',')[OFFSET(4)] AS FLOAT64) AS ActivityDensity,
  CAST(SPLIT(V2Tone, ',')[OFFSET(5)] AS FLOAT64) AS SelfDensity,

  -- All matched themes as pipe-delimited string, I created this variable so i can address headlines which match more than one of the themes as i would expect them to be more relevent 
  ARRAY_TO_STRING(
    ARRAY(
      SELECT theme FROM UNNEST([
        IF(CONTAINS_SUBSTR(Themes, 'PERSONAL_DATA_PROTECTION'), 'PERSONAL_DATA_PROTECTION', NULL),
        IF(CONTAINS_SUBSTR(Themes, 'DATA_SECURITY'),            'DATA_SECURITY',            NULL),
        IF(CONTAINS_SUBSTR(Themes, 'DATA_PRIVACY'),             'DATA_PRIVACY',             NULL)
      ]) AS theme
      WHERE theme IS NOT NULL
    )
  , '|') AS MatchedThemes,

  -- Theme match count , a simple count variable of the MatchedThemes , so when modelling I can easily check how many (1-3) themes the article has been tagged as. 
  (
    IF(CONTAINS_SUBSTR(Themes, 'PERSONAL_DATA_PROTECTION'), 1, 0) +
    IF(CONTAINS_SUBSTR(Themes, 'DATA_SECURITY'),            1, 0) +
    IF(CONTAINS_SUBSTR(Themes, 'DATA_PRIVACY'),             1, 0)
  ) AS ThemeMatchCount,


  

FROM `gdelt-bq.gdeltv2.gkg`

WHERE
  DATE BETWEEN 20150101000000 AND 20261231235959 -- 
  AND REGEXP_CONTAINS(DocumentIdentifier,'.co.uk')
  AND REGEXP_CONTAINS(V2Locations, r'#United Kingdom') -- Although imperfect, this is the more logical way for me to filter to UK, in tandem with my ASCII filter there should be minimal issues at scale.
  AND REGEXP_CONTAINS(Extras, r'<PAGE_TITLE>(.*?)</PAGE_TITLE>') -- removes entries with no headline
  AND NOT REGEXP_CONTAINS(
    REGEXP_EXTRACT(Extras, r'<PAGE_TITLE>(.*?)</PAGE_TITLE>'), 
    r'&#x[0-9A-Fa-f]+;' -- excludes non-latin headlines , this is a bias i should mention as this will also exclude any latin characters which may in turn exclude mentions of forein names in headlines , but the intention is to exclude non-english headlines to keep to my UK-english focus, since i am unable to feasibly assess chinese headlines for example. 
  )
  AND (
    CONTAINS_SUBSTR(Themes, 'PERSONAL_DATA_PROTECTION')
    OR CONTAINS_SUBSTR(Themes, 'DATA_SECURITY')
    OR CONTAINS_SUBSTR(Themes, 'DATA_PRIVACY')
  ) -- After exporting the full themes list from GDELTs site and manually filtering for data relates tags, these 3 are the most relevant - note i chose to drop soc-emergingtechnologies as it brought it lots of unrelated headlines. same for big_tech it seemed to be a generously spread buzzword tag. 

QUALIFY ROW_NUMBER() OVER (
  PARTITION BY
    REGEXP_EXTRACT(Extras, r'<PAGE_TITLE>(.*?)</PAGE_TITLE>'),
    CAST(FLOOR(DATE / 1000000) AS INT64)
  ORDER BY DATE ASC
) = 1 -- this logic should be excluding duplicate headlines where the dates are the same , as this might skew results during news-outlet analysis I have added a syndicateCount variable , so i know for a given headline, how many times it was reported on the same day - this will still drop tone score differences and add a small level of inaccuracy but is necesaary to keep this feasible for me!

LIMIT 1000
